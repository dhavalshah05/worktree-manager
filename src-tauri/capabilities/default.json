{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:allow-confirm",
    "dialog:allow-open",
    "clipboard-manager:allow-write-text",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "git-worktree-list",
          "cmd": "git",
          "args": [
            "worktree",
            "list"
          ]
        },
        {
          "name": "git-worktree-add",
          "cmd": "git",
          "args": [
            "worktree",
            "add",
            {
              "validator": ".+"
            },
            "-b",
            {
              "validator": ".+"
            },
            {
              "validator": ".+"
            }
          ]
        },
        {
          "name": "git-worktree-remove",
          "cmd": "git",
          "args": [
            "worktree",
            "remove",
            {
              "validator": ".+"
            },
            "--force"
          ]
        },
        {
          "name": "git-worktree-prune",
          "cmd": "git",
          "args": [
            "worktree",
            "prune",
            "--verbose"
          ]
        },
        {
          "name": "open-antigravity-by-name",
          "cmd": "/usr/bin/open",
          "args": [
            {
              "validator": ".+"
            },
            "-a",
            "Antigravity"
          ]
        },
        {
          "name": "open-antigravity-by-bundle",
          "cmd": "/usr/bin/open",
          "args": [
            {
              "validator": ".+"
            },
            "-b",
            "com.google.antigravity"
          ]
        },
        {
          "name": "open-antigravity-by-app-path",
          "cmd": "/usr/bin/open",
          "args": [
            {
              "validator": ".+"
            },
            "-a",
            "/Applications/Antigravity.app"
          ]
        },
        {
          "name": "open-codex-by-name",
          "cmd": "/usr/bin/open",
          "args": [
            {
              "validator": ".+"
            },
            "-a",
            "Codex"
          ]
        },
        {
          "name": "open-codex-by-bundle",
          "cmd": "/usr/bin/open",
          "args": [
            {
              "validator": ".+"
            },
            "-b",
            "com.openai.codex"
          ]
        },
        {
          "name": "open-codex-by-app-path",
          "cmd": "/usr/bin/open",
          "args": [
            {
              "validator": ".+"
            },
            "-a",
            "/Applications/Codex.app"
          ]
        },
        {
          "name": "open-intellij-by-name",
          "cmd": "/usr/bin/open",
          "args": [
            {
              "validator": ".+"
            },
            "-a",
            "IntelliJ IDEA"
          ]
        },
        {
          "name": "open-intellij-by-bundle",
          "cmd": "/usr/bin/open",
          "args": [
            {
              "validator": ".+"
            },
            "-b",
            "com.jetbrains.intellij"
          ]
        },
        {
          "name": "open-intellij-by-user-app-path",
          "cmd": "/usr/bin/open",
          "args": [
            {
              "validator": ".+"
            },
            "-a",
            "/Users/dhavalshah/Applications/IntelliJ IDEA.app"
          ]
        },
        {
          "name": "open-intellij-by-system-app-path",
          "cmd": "/usr/bin/open",
          "args": [
            {
              "validator": ".+"
            },
            "-a",
            "/Applications/IntelliJ IDEA.app"
          ]
        },
        {
          "name": "open-cursor-by-name",
          "cmd": "/usr/bin/open",
          "args": [
            {
              "validator": ".+"
            },
            "-a",
            "Cursor"
          ]
        },
        {
          "name": "open-cursor-by-bundle",
          "cmd": "/usr/bin/open",
          "args": [
            {
              "validator": ".+"
            },
            "-b",
            "com.todesktop.230313mzl4w4u92"
          ]
        },
        {
          "name": "open-cursor-by-app-path",
          "cmd": "/usr/bin/open",
          "args": [
            {
              "validator": ".+"
            },
            "-a",
            "/Applications/Cursor.app"
          ]
        },
        {
          "name": "open-android-studio-by-name",
          "cmd": "/usr/bin/open",
          "args": [
            {
              "validator": ".+"
            },
            "-a",
            "Android Studio"
          ]
        },
        {
          "name": "open-android-studio-by-bundle",
          "cmd": "/usr/bin/open",
          "args": [
            {
              "validator": ".+"
            },
            "-b",
            "com.google.android.studio"
          ]
        },
        {
          "name": "open-android-studio-by-app-path",
          "cmd": "/usr/bin/open",
          "args": [
            {
              "validator": ".+"
            },
            "-a",
            "/Applications/Android Studio.app"
          ]
        },
        {
          "name": "open-terminal-by-name",
          "cmd": "/usr/bin/open",
          "args": [
            {
              "validator": ".+"
            },
            "-a",
            "Terminal"
          ]
        },
        {
          "name": "open-terminal-by-bundle",
          "cmd": "/usr/bin/open",
          "args": [
            {
              "validator": ".+"
            },
            "-b",
            "com.apple.Terminal"
          ]
        },
        {
          "name": "open-terminal-by-app-path",
          "cmd": "/usr/bin/open",
          "args": [
            {
              "validator": ".+"
            },
            "-a",
            "/Applications/Utilities/Terminal.app"
          ]
        }
      ]
    }
  ]
}
